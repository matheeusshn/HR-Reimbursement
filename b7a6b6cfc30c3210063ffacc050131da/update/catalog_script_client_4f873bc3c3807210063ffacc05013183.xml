        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading) {
   if (isLoading) return;

   if (!newValue){
	return;
	}

   var today = new Date();
   var expenseDate = new Date(newValue);
   today.setHours(0,0,0,0);
   expenseDate.setHours(0,0,0,0);
   
   if(expenseDate > today) {
	g_form.clearValue('expense_date');
	g_form.showFieldMsg('expense_date', 'Expense Date cannot be in the future', 'error');
   } else { 
	g_form.hideFieldMsg('expense_date', true);
   }
}]]></script>
