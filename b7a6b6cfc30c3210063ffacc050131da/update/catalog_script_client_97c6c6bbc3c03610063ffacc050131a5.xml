        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading, isTemplate) {
    if (isLoading || newValue === '') {
        return;
    }

    var value = newValue.trim();

    value = value.replace(',', '.');

    var regex = /^\d{1,7}(\.\d{1,2})?$/;

    if (!regex.test(value)) {
		g_form.clearValue('amount_brl');
        g_form.showFieldMsg('amount_brl', 'Please enter a valid amount (up to 7 digits and 2 decimals).', 'error');
        return;
    }

    g_form.setValue('amount_brl', value);
    g_form.hideFieldMsg('amount_brl', true);
}]]></script>
